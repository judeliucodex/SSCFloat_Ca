    if (action == "doubletimedactivedepth") {
      bool homedCopy = false;
      if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
        homedCopy = isHomed;
        xSemaphoreGive(modeLock);
      }

      if (homedCopy) {
        float target1Cm = -250.0;
        float target2Cm = -40.0;
        uint32_t holdTimeMs = 30000;
        if (xSemaphoreTake(configLock, portMAX_DELAY)) {
          target1Cm = doubleTargetDepth1Cm;
          target2Cm = doubleTargetDepth2Cm;
          holdTimeMs = floatWaitTimeMs;
          xSemaphoreGive(configLock);
        }

        float target1Meters = 0.0;
        float target2Meters = 0.0;
        uint32_t lastDepthMs = 0;
        bool depthFresh = false;
        uint32_t nowMs = millis();
        if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
          lastDepthMs = lastValidDepthMs;
          depthFresh = depthReadingIsFresh(nowMs, lastDepthMs);
          if (depthFresh) {
            float sequenceStartDepth = currentRelativeDepth;
            target1Meters = sequenceStartDepth + (target1Cm / 100.0);
            target2Meters = sequenceStartDepth + (target2Cm / 100.0);
            targetDepth = target1Meters;
          }
          xSemaphoreGive(dataLock);
        }

        if (depthFresh) {
          if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
            if (isHomed) {
              doubleActiveTarget1 = target1Meters;
              doubleActiveTarget2 = target2Meters;
              doubleActiveHoldTimeMs = holdTimeMs;
              currentMode = MODE_DOUBLE_TIMED_ACTIVE_DEPTH;
              currentSubStatus = "SEEKING DEPTH 1";
              holdSecondsRemaining = 0;
              safeLog("[SEQUENCE] Double timed active depth started. Target 1: " + String(target1Meters * 100.0) + "cm, Target 2: " + String(target2Meters * 100.0) + "cm.");
            }
            xSemaphoreGive(modeLock);
          }
        } else {
          uint32_t ageMs = lastDepthMs > 0 ? (millis() - lastDepthMs) : 0;
          safeLog("[ACTIVE ERROR] Cannot start double timed active depth: pressure sensor data is offline or stale (age " + String(ageMs) + "ms).");
        }
      }

      server.sendHeader("Location", "/control");
      server.send(303);
      return;
    }

    if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
      if (action == "stop") {
        currentMode = MODE_IDLE;
        currentSubStatus = "IDLE";
        holdSecondsRemaining = 0;
        safeLog("[E-STOP] Emergency Stop triggered by user!");
      } 
      else if (action == "home") {
        currentMode = MODE_HOMING;
        isHomed = false;
        currentSubStatus = "HOMING";
        holdSecondsRemaining = 0;
        safeLog("[SYSTEM] Initiating syringe homing procedure...");
      } 
      else if (action == "manual") {
        manualDir = (server.arg("dir") == "down");
        manualDurationMs = server.arg("time").toInt() * 1000;
        manualStartTime = millis();
        currentMode = MODE_MANUAL_PULSE;
        currentSubStatus = "MANUAL";
        holdSecondsRemaining = 0;
        safeLog("[MANUAL] Pulsing motor. Direction: " + String(manualDir ? "DOWN" : "UP"));
      } 
      else if (action == "targetstep" && isHomed) {
        targetStepPos = server.arg("steps").toInt();
        currentMode = MODE_TARGET_STEP_SEQUENCE;
        holdSecondsRemaining = 0;
        safeLog("[SEQUENCE] Starting Target Step sequence. Absolute Target: " + String(targetStepPos));
      }
      else if (action == "fullbump" && isHomed) {
        currentMode = MODE_FULL_BUMP_SEQUENCE;
        holdSecondsRemaining = 0;
        safeLog("[SEQUENCE] Starting Full Bump sequence.");
      } 
      else if ((action == "activedepth" || action == "timedactivehold") && isHomed) {
        bool timedMode = action == "timedactivehold";
        float holdTargetCm = -40.0;
        float newTargetDepth = 0.0;
        uint32_t lastDepthMs = 0;
        bool depthFresh = false;
        
        if (xSemaphoreTake(configLock, portMAX_DELAY)) {
          holdTargetCm = targetHoldDepthCm;
          xSemaphoreGive(configLock);
        }
        
        if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
          lastDepthMs = lastValidDepthMs;
          depthFresh = depthReadingIsFresh(millis(), lastDepthMs);
          if (depthFresh) {
            targetDepth = currentRelativeDepth + (holdTargetCm / 100.0);
            newTargetDepth = targetDepth;
          }
          xSemaphoreGive(dataLock);
        }

        if (depthFresh) {
          currentMode = timedMode ? MODE_TIMED_ACTIVE_HOLD : MODE_ACTIVE_DEPTH;
          if (timedMode) currentSubStatus = "SEEKING TIMED HOLD";
          holdSecondsRemaining = 0;
          safeLog(String("[SEQUENCE] ") + (timedMode ? "Timed active hold" : "PD active hold") + " started. Target: " + String(newTargetDepth * 100.0) + "cm.");
        } else {
          uint32_t ageMs = lastDepthMs > 0 ? (millis() - lastDepthMs) : 0;
          safeLog("[ACTIVE ERROR] Cannot start PD hold: pressure sensor data is offline or stale (age " + String(ageMs) + "ms).");
        }
      }
      xSemaphoreGive(modeLock);
    }
    server.sendHeader("Location", "/control");
    server.send(303);
    return;
  }

  SystemMode modeCopy = MODE_IDLE;
  bool isHomedCopy = false;
  String statusCopy = "IDLE";
  long holdRemainingCopy = 0;
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    modeCopy = currentMode;
    isHomedCopy = isHomed;
    statusCopy = currentSubStatus;
    holdRemainingCopy = holdSecondsRemaining;
    xSemaphoreGive(modeLock);
  }
  
  float currentHoldDisplay = -40.0;
  if (xSemaphoreTake(configLock, portMAX_DELAY)) {
    currentHoldDisplay = targetHoldDepthCm;
    xSemaphoreGive(configLock);
  }

  String html;
  html.reserve(7000);
  html = "<html><head><meta name='viewport' content='width=device-width, initial-scale=1'>";
  html += "<style>body{font-family:Arial; text-align:center;} button { padding: 15px; margin: 10px auto; font-size: 18px; width: 90%; max-width: 400px; display: block; border-radius: 5px; border: none; cursor: pointer; font-weight: bold;} ";
  html += "input, select { padding:12px; margin:5px auto; font-size:16px; width:90%; max-width:400px; display: block; border-radius: 5px; border: 1px solid #ccc; box-sizing: border-box; }";
  html += ".stop { background-color: #ff4c4c; color: white; } .manual { background-color: #333; color: white; } .config { background-color: #4CAF50; color: white; }";
  html += "</style></head><body><h2>MATE ROV Float Controller</h2>";

  if (modeCopy == MODE_FULL_BUMP_SEQUENCE || modeCopy == MODE_TARGET_STEP_SEQUENCE || modeCopy == MODE_ACTIVE_DEPTH || modeCopy == MODE_TIMED_ACTIVE_HOLD || modeCopy == MODE_DOUBLE_TIMED_ACTIVE_DEPTH) {
    html += "<div style='padding:15px; background:#e3f2fd; border:2px solid #2196f3; border-radius:10px; margin:10px auto; width:90%; max-width:400px;'>";
