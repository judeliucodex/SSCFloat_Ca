// ==========================================
// --- THREAD-SAFE WIRELESS LOGGING FUNCTION ---
// ==========================================
void safeLog(String msg) {
  Serial.println(msg);
  if (logLock != NULL && xSemaphoreTake(logLock, portMAX_DELAY)) {
    liveLogBuffer += "[" + String(millis() / 1000) + "s] " + msg + "\n";
    if (liveLogBuffer.length() > 3000) {
      liveLogBuffer = liveLogBuffer.substring(liveLogBuffer.length() - 1500); 
    }
    xSemaphoreGive(logLock);
  }
}

String systemModeName(SystemMode mode) {
  switch (mode) {
    case MODE_IDLE: return "IDLE";
    case MODE_HOMING: return "HOMING";
    case MODE_MANUAL_PULSE: return "MANUAL";
    case MODE_FULL_BUMP_SEQUENCE: return "FULL BUMP";
    case MODE_TARGET_STEP_SEQUENCE: return "TARGET STEP";
    case MODE_ACTIVE_DEPTH: return "ACTIVE DEPTH";
    case MODE_TIMED_ACTIVE_HOLD: return "TIMED ACTIVE HOLD";
    case MODE_DOUBLE_TIMED_ACTIVE_DEPTH: return "DOUBLE TIMED ACTIVE DEPTH";
  }
  return "UNKNOWN";
}

bool depthReadingIsFresh(uint32_t nowMs, uint32_t lastDepthMs) {
  return sensorActive && lastDepthMs > 0 && (nowMs - lastDepthMs) <= SENSOR_STALE_TIMEOUT_MS;
}

bool initializeSensorBaseline(String logPrefix) {
  Wire.beginTransmission(0x76);
  if (Wire.endTransmission() != 0 || !sensor.init()) {
    return false;
  }

  sensor.setFluidDensity(997);
  sensor.read();
  float initialPressure = sensor.pressure();

  if (initialPressure < MIN_VALID_PRESSURE || initialPressure > MAX_VALID_PRESSURE) {
    safeLog(logPrefix + " Sensor found, but initial data is garbage: " + String(initialPressure) + " hPa.");
    return false;
  }

  float baselineDepth = sensor.depth();
  uint32_t nowMs = millis();

  if (dataLock != NULL && xSemaphoreTake(dataLock, portMAX_DELAY)) {
    surfaceDepthOffset = baselineDepth;
    currentRelativeDepth = 0.0;
    depthWindow[0] = 0.0;
    depthWindow[1] = 0.0;
    depthWindow[2] = 0.0;
    windowIdx = 0;
    lastValidDepthMs = nowMs;
    xSemaphoreGive(dataLock);
  } else {
    surfaceDepthOffset = baselineDepth;
    currentRelativeDepth = 0.0;
    depthWindow[0] = 0.0;
    depthWindow[1] = 0.0;
    depthWindow[2] = 0.0;
    windowIdx = 0;
    lastValidDepthMs = nowMs;
  }

  sensorActive = true;
  safeLog(logPrefix + " MS5837 pressure sensor baseline loaded successfully.");
  return true;
}

// ==========================================
// --- STEPPER HELPER FUNCTION ---
// ==========================================
bool singleStep(bool dirHigh, int overrideSpeedUs = -1) {
  if (dirHigh) {
    if (digitalRead(BUTTON_PIN_1) == LOW) return false;
    digitalWrite(dirPin, HIGH);
  } else {
    if (digitalRead(BUTTON_PIN_2) == LOW) return false;
    digitalWrite(dirPin, LOW);
  }

  digitalWrite(stepPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(stepPin, LOW);

  int speedToUse = (overrideSpeedUs == -1) ? motorSpeed : overrideSpeedUs;
  int delayMs = speedToUse / 1000;
  
  if (delayMs > 0) {
    vTaskDelay(pdMS_TO_TICKS(delayMs));
  } else {
    delayMicroseconds(speedToUse);
  }

  if (dirHigh) currentStepperPos++;
  else currentStepperPos--;
  
  return true;
}

// ==========================================
// --- SENSOR TASK (CORE 0) ---
// ==========================================
void sensorTask(void *parameter) {
  static uint32_t lastLogTime = 0;
  static uint32_t lastSensorRetryTime = 0;
  TickType_t xLastWakeTime = xTaskGetTickCount();

  while(1) {
    if (sensorActive) {
      sensor.read();
      float currentPressure = sensor.pressure();

      // --- OUTLIER REJECTION FILTER ---
      if (currentPressure < MIN_VALID_PRESSURE || currentPressure > MAX_VALID_PRESSURE) {
        safeLog("[SENSOR WARN] Garbage data blocked: " + String(currentPressure) + " hPa");
      } else {
        uint32_t logInt = 100;
        if (xSemaphoreTake(configLock, portMAX_DELAY)) {
          logInt = sensorLogIntervalMs;
          xSemaphoreGive(configLock);
        }

        if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
          float rawRelativeDepth = -(sensor.depth() - surfaceDepthOffset);

          depthWindow[windowIdx] = rawRelativeDepth;
          windowIdx = (windowIdx + 1) % 3;

          float a = depthWindow[0], b = depthWindow[1], c = depthWindow[2];
          if (a > b) { float t = a; a = b; b = t; }
          if (a > c) { float t = a; a = c; c = t; }
          if (b > c) { float t = b; b = c; c = t; }
          currentRelativeDepth = b;
          lastValidDepthMs = millis();

          if (millis() - lastLogTime >= logInt) {
            snprintf(dataPackets[sensorIdx], 64, "RN03 %lus %.1fhPa %.2fm Pos:%ld", 
                     (millis() / 1000), 
                     currentPressure, 
                     currentRelativeDepth, 
                     currentStepperPos);
                     
            sensorIdx = (sensorIdx + 1) % MAX_PACKETS;
            if(iterationCount < MAX_PACKETS) iterationCount++;
            lastLogTime = millis();
          }
          xSemaphoreGive(dataLock);
        }
      }
    } else if (millis() - lastSensorRetryTime >= SENSOR_RETRY_INTERVAL_MS) {
      lastSensorRetryTime = millis();
      initializeSensorBaseline("[SENSOR RETRY]");
    }

    uint32_t delayMs = 50;
    if (xSemaphoreTake(configLock, portMAX_DELAY)) {
      delayMs = sensorReadIntervalMs;
      xSemaphoreGive(configLock);
    }
    vTaskDelayUntil(&xLastWakeTime, pdMS_TO_TICKS(delayMs));
  }
}

