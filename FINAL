void handleData() {
  String statusCopy = "UNKNOWN";
  long holdRemainingCopy = 0;
  SystemMode modeCopy = MODE_IDLE;
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    statusCopy = currentSubStatus;
    holdRemainingCopy = holdSecondsRemaining;
    modeCopy = currentMode;
    xSemaphoreGive(modeLock);
  }

  bool sensorActiveCopy = sensorActive;
  float depthCopy = 0.0;
  float targetCopy = 0.0;
  uint32_t lastDepthCopy = 0;
  int total = 0;
  int startIdx = 0;
  if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
    depthCopy = currentRelativeDepth;
    targetCopy = targetDepth;
    lastDepthCopy = lastValidDepthMs;
    total = iterationCount < MAX_PACKETS ? iterationCount : MAX_PACKETS;
    startIdx = sensorIdx;
    xSemaphoreGive(dataLock);
  }

  String header;
  header.reserve(320);
  header = "Mode: " + systemModeName(modeCopy) + "\n";
  header += "Status: " + statusCopy + " | Hold Rem: " + String(holdRemainingCopy) + "s\n";

  if (!sensorActiveCopy) {
    header += "Current Depth: -- cm (SENSOR OFFLINE)\n";
    header += "ERROR: I2C communication with MS5837 failed. Telemetry halted.\n";
  } else {
    header += "Current Depth: " + String(depthCopy * 100.0) + " cm\n";
    if (!depthReadingIsFresh(millis(), lastDepthCopy)) {
      header += "WARNING: Depth reading is stale. Active depth hold is blocked.\n";
    }
    if (modeCopy == MODE_ACTIVE_DEPTH || modeCopy == MODE_TIMED_ACTIVE_HOLD || modeCopy == MODE_DOUBLE_TIMED_ACTIVE_DEPTH) {
      header += "Target Depth: " + String(targetCopy * 100.0) + " cm\n";
    }
  }

  server.setContentLength(CONTENT_LENGTH_UNKNOWN);
  server.send(200, "text/plain", "");
  server.sendContent(header);

  if (sensorActiveCopy) {
    char packet[64];
    for (int i = 0; i < total; i++) {
      int idx = (startIdx - 1 - i + MAX_PACKETS) % MAX_PACKETS;
      if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
        snprintf(packet, sizeof(packet), "%s", dataPackets[idx]);
        xSemaphoreGive(dataLock);
        server.sendContent(String(packet) + "\n");
      }
    }
  }
  server.sendContent("");
}

