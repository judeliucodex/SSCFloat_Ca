  if (isHomedCopy) html += "<button type='submit' class='manual' style='background-color:#e91e63;'>Run PD Active Hold (Target " + String(currentHoldDisplay) + "cm)</button></form>";
  else html += "<button type='button' class='manual' style='background:#ccc' disabled>Home First</button></form>";

  html += "<form action='/control' method='GET'><input type='hidden' name='action' value='timedactivehold'>";
  if (isHomedCopy) html += "<button type='submit' class='manual' style='background-color:#3f51b5;'>Timed active hold</button></form>";
  else html += "<button type='button' class='manual' style='background:#ccc' disabled>Home First</button></form>";

  html += "<form action='/control' method='GET'><input type='hidden' name='action' value='doubletimedactivedepth'>";
