// ==========================================
// --- MOTOR BEHAVIORS & SEQUENCES ---
// ==========================================
void surfaceEmergency() {
  safeLog("[SAFETY] Surfacing active. Driving upward to limit switch...");
  while(digitalRead(BUTTON_PIN_2) == HIGH && currentMode != MODE_HOMING && currentMode != MODE_IDLE) {
    singleStep(false); 
    vTaskDelay(1);
  }
  if (digitalRead(BUTTON_PIN_2) == LOW) {
    safeLog("[SAFETY] Upper limit switch triggered successfully.");
  }
}

void executeHoldAndSurface(SystemMode expectedMode, String logPrefix) {
  if (currentMode == expectedMode) {
    if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
      currentSubStatus = "HOLDING";
      xSemaphoreGive(modeLock);
    }
    safeLog("[" + logPrefix + " STATUS] Target reached. Holding.");
    uint32_t holdTimeMs = 30000;
    
    if (xSemaphoreTake(configLock, portMAX_DELAY)) {
      holdTimeMs = floatWaitTimeMs;
      xSemaphoreGive(configLock);
    }

    uint32_t startHold = millis();
    while (millis() - startHold < holdTimeMs && currentMode == expectedMode) {
      long remainingSeconds = (holdTimeMs / 1000) - ((millis() - startHold) / 1000);
      if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
        holdSecondsRemaining = remainingSeconds;
        xSemaphoreGive(modeLock);
      }
      vTaskDelay(100);
    }
  }

  if (currentMode == expectedMode) {
    if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
      currentSubStatus = "SURFACING";
      holdSecondsRemaining = 0;
      xSemaphoreGive(modeLock);
    }
    surfaceEmergency();
  }
  
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    currentSubStatus = "IDLE";
    holdSecondsRemaining = 0;
    currentMode = MODE_IDLE;
    xSemaphoreGive(modeLock);
  }
  safeLog("[" + logPrefix + " STATUS] Sequence complete. System IDLE.");
}

void runTargetStepSequence() {
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    currentSubStatus = "MOVING";
    holdSecondsRemaining = 0;
    xSemaphoreGive(modeLock);
  }
  safeLog("[STEP STATUS] Phase changed to: MOVING to step " + String(targetStepPos));

  while (currentMode == MODE_TARGET_STEP_SEQUENCE && currentStepperPos != targetStepPos) {
    bool dirDown = (targetStepPos > currentStepperPos); 
    
    if (dirDown && digitalRead(BUTTON_PIN_1) == LOW) {
      safeLog("[WARNING] Bottom limit hit before reaching target step!");
      break;
    }
    if (!dirDown && digitalRead(BUTTON_PIN_2) == LOW) {
      safeLog("[WARNING] Top limit hit before reaching target step!");
      break;
    }
    singleStep(dirDown);
  }

  executeHoldAndSurface(MODE_TARGET_STEP_SEQUENCE, "STEP");
}

void runFullBumpSequence() {
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    currentSubStatus = "SINKING (BUMP)";
    holdSecondsRemaining = 0;
    xSemaphoreGive(modeLock);
  }
  safeLog("[BUMP STATUS] Phase changed to: SINKING");

  while (currentMode == MODE_FULL_BUMP_SEQUENCE) {
    if (digitalRead(BUTTON_PIN_1) == LOW) {
      safeLog("[BUMP STATUS] Limit switch reached. Sinking complete.");
      break;
    }
    singleStep(true);
  }

  executeHoldAndSurface(MODE_FULL_BUMP_SEQUENCE, "BUMP");
}

void runActiveDepthSequence() {
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    currentSubStatus = "ACTIVE HOLD (PD)";
    holdSecondsRemaining = 0;
    xSemaphoreGive(modeLock);
  }
  safeLog("[ACTIVE STATUS] PD active hold engaged. Target: " + String(targetDepth * 100.0) + "cm.");

  float toleranceMeters = 0.03;
  float currentKp = 2500.0, currentKd = 800.0;
  int s_speed = 6000, u_speed = 6000;
  uint32_t dtMs = 100;
  float surfScale = 0.5;

  if (xSemaphoreTake(configLock, pdMS_TO_TICKS(50))) {
    toleranceMeters = depthToleranceCm / 100.0; 
    currentKp = Kp;
    currentKd = Kd;
    s_speed = sinkHoldSpeed;
    u_speed = surfaceHoldSpeed;
    dtMs = pdLoopDelayMs;
    surfScale = surfaceOutputScale;
    xSemaphoreGive(configLock);
  }

  float lastError = 0.0;
  bool correctionActive = false;
  uint32_t lastLoopTime = 0;
  bool firstIteration = true;

  while (currentMode == MODE_ACTIVE_DEPTH) {
    uint32_t loopStart = millis();

    float currentDepth = 0.0;
    uint32_t lastDepthMs = 0;
    bool depthFresh = false;
    if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
      currentDepth = currentRelativeDepth;
      lastDepthMs = lastValidDepthMs;
      depthFresh = depthReadingIsFresh(loopStart, lastDepthMs);
      xSemaphoreGive(dataLock);
    }

    if (!depthFresh) {
      uint32_t ageMs = lastDepthMs > 0 ? (loopStart - lastDepthMs) : 0;
      safeLog("[ACTIVE ERROR] Pressure sensor data stale during PD hold (age " + String(ageMs) + "ms). Surfacing.");
      surfaceEmergency();
      break;
    }

    float error = currentDepth - targetDepth;

    float actualDtSec;
    if (firstIteration) {
      actualDtSec = dtMs / 1000.0f;
      firstIteration = false;
    } else {
      actualDtSec = (loopStart - lastLoopTime) / 1000.0f;
      if (actualDtSec < 0.001f) actualDtSec = 0.001f;
    }
    lastLoopTime = loopStart;

    float derivative = (error - lastError) / actualDtSec;
    lastError = error;

    float output = (currentKp * error) + (currentKd * derivative);
    if (output < 0) output *= surfScale;

    if (!correctionActive) {
      if (fabs(error) > toleranceMeters) correctionActive = true;
    } else {
      if (fabs(error) < toleranceMeters * 0.7f) correctionActive = false;
    }

    if (correctionActive) {
      int stepsToTake = abs((int)output);
      if (stepsToTake > 500) stepsToTake = 500;

      if (output > 0) {
        bool limitHit = false;
        for (int i = 0; i < stepsToTake && currentMode == MODE_ACTIVE_DEPTH; i++) {
          if (!singleStep(true, s_speed)) { limitHit = true; break; }
        }
        if (limitHit && digitalRead(BUTTON_PIN_1) == LOW) {
          safeLog("[SAFETY] Bottom limit hit during PD — emergency surfacing!");
          surfaceEmergency();
          break;
        }
      } else if (output < 0) {
        for (int i = 0; i < stepsToTake && currentMode == MODE_ACTIVE_DEPTH; i++) {
          if (!singleStep(false, u_speed)) break; 
        }
      }
    }

    uint32_t elapsed = millis() - loopStart;
    if (elapsed < dtMs) {
      vTaskDelay(pdMS_TO_TICKS(dtMs - elapsed));
    }
  }

  if (currentMode == MODE_ACTIVE_DEPTH) {
    safeLog("[ACTIVE STATUS] PD hold terminated. System IDLE.");
    if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
      currentSubStatus = "IDLE";
      holdSecondsRemaining = 0;
      currentMode = MODE_IDLE;
      xSemaphoreGive(modeLock);
    }
  }
}

void runTimedActiveHoldSequence() {
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    currentSubStatus = "SEEKING TIMED HOLD";
    holdSecondsRemaining = 0;
    xSemaphoreGive(modeLock);
  }
  safeLog("[TIMED ACTIVE] Timed active hold engaged. Target: " + String(targetDepth * 100.0) + "cm.");

  float toleranceMeters = 0.03;
  float currentKp = 2500.0, currentKd = 800.0;
  int s_speed = 6000, u_speed = 6000;
  uint32_t dtMs = 100;
  uint32_t holdTimeMs = 30000;
  float surfScale = 0.5;

  if (xSemaphoreTake(configLock, pdMS_TO_TICKS(50))) {
    toleranceMeters = depthToleranceCm / 100.0;
    currentKp = Kp;
    currentKd = Kd;
    s_speed = sinkHoldSpeed;
    u_speed = surfaceHoldSpeed;
    dtMs = pdLoopDelayMs;
    holdTimeMs = floatWaitTimeMs;
    surfScale = surfaceOutputScale;
    xSemaphoreGive(configLock);
  }

  float lastError = 0.0;
  bool correctionActive = false;
  uint32_t lastLoopTime = 0;
  bool firstIteration = true;
  bool holdTimerStarted = false;
  uint32_t holdStartMs = 0;

  while (currentMode == MODE_TIMED_ACTIVE_HOLD) {
    uint32_t loopStart = millis();

    float currentDepth = 0.0;
    uint32_t lastDepthMs = 0;
    bool depthFresh = false;
    if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
      currentDepth = currentRelativeDepth;
      lastDepthMs = lastValidDepthMs;
      depthFresh = depthReadingIsFresh(loopStart, lastDepthMs);
      xSemaphoreGive(dataLock);
    }

    if (!depthFresh) {
      uint32_t ageMs = lastDepthMs > 0 ? (loopStart - lastDepthMs) : 0;
      safeLog("[TIMED ACTIVE ERROR] Pressure sensor data stale during timed hold (age " + String(ageMs) + "ms). Surfacing.");
      break;
    }

    float error = currentDepth - targetDepth;

    if (!holdTimerStarted && fabs(error) <= toleranceMeters) {
      holdTimerStarted = true;
      holdStartMs = loopStart;
      if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
        currentSubStatus = "TIMED HOLD (PD)";
        holdSecondsRemaining = holdTimeMs / 1000;
        xSemaphoreGive(modeLock);
      }
      safeLog("[TIMED ACTIVE] Target deadband reached. Hold timer started.");
    }

    if (holdTimerStarted) {
      uint32_t elapsedHoldMs = loopStart - holdStartMs;
      long remainingSeconds = 0;
      if (elapsedHoldMs < holdTimeMs) {
        remainingSeconds = (holdTimeMs - elapsedHoldMs + 999) / 1000;
      }

      if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
        holdSecondsRemaining = remainingSeconds;
        xSemaphoreGive(modeLock);
      }

      if (elapsedHoldMs >= holdTimeMs) {
        safeLog("[TIMED ACTIVE] Hold time complete. Surfacing.");
        break;
      }
    }

    float actualDtSec;
    if (firstIteration) {
      actualDtSec = dtMs / 1000.0f;
      firstIteration = false;
    } else {
      actualDtSec = (loopStart - lastLoopTime) / 1000.0f;
      if (actualDtSec < 0.001f) actualDtSec = 0.001f;
    }
    lastLoopTime = loopStart;

    float derivative = (error - lastError) / actualDtSec;
    lastError = error;

    float output = (currentKp * error) + (currentKd * derivative);
    if (output < 0) output *= surfScale;

    if (!correctionActive) {
      if (fabs(error) > toleranceMeters) correctionActive = true;
    } else {
      if (fabs(error) < toleranceMeters * 0.7f) correctionActive = false;
    }

    if (correctionActive) {
      int stepsToTake = abs((int)output);
      if (stepsToTake > 500) stepsToTake = 500;

      if (output > 0) {
        bool limitHit = false;
        for (int i = 0; i < stepsToTake && currentMode == MODE_TIMED_ACTIVE_HOLD; i++) {
          if (!singleStep(true, s_speed)) { limitHit = true; break; }
        }
        if (limitHit && digitalRead(BUTTON_PIN_1) == LOW) {
          safeLog("[SAFETY] Bottom limit hit during timed PD hold. Surfacing.");
          break;
        }
      } else if (output < 0) {
        for (int i = 0; i < stepsToTake && currentMode == MODE_TIMED_ACTIVE_HOLD; i++) {
          if (!singleStep(false, u_speed)) break;
        }
      }
    }

    uint32_t elapsed = millis() - loopStart;
    if (elapsed < dtMs) {
      vTaskDelay(pdMS_TO_TICKS(dtMs - elapsed));
    }
  }

  if (currentMode == MODE_TIMED_ACTIVE_HOLD) {
    if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
      currentSubStatus = "SURFACING";
      holdSecondsRemaining = 0;
      xSemaphoreGive(modeLock);
    }

    surfaceEmergency();

    if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
      currentSubStatus = "IDLE";
      holdSecondsRemaining = 0;
      currentMode = MODE_IDLE;
      xSemaphoreGive(modeLock);
    }
    safeLog("[TIMED ACTIVE] Timed active hold complete. System IDLE.");
  }
}

bool runDoubleTimedActiveStage(SystemMode expectedMode,
                               float stageTargetDepth,
                               const char* seekingStatus,
                               const char* holdingStatus,
                               const char* stageLabel,
                               const char* completionLog,
                               uint32_t holdTimeMs,
                               float toleranceMeters,
                               float currentKp,
                               float currentKd,
                               int s_speed,
                               int u_speed,
                               uint32_t dtMs,
                               float surfScale) {
  if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
    targetDepth = stageTargetDepth;
    xSemaphoreGive(dataLock);
  }

  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    currentSubStatus = seekingStatus;
    holdSecondsRemaining = 0;
    xSemaphoreGive(modeLock);
  }

  safeLog(String("[DOUBLE ACTIVE] Seeking ") + stageLabel + ". Target: " + String(stageTargetDepth * 100.0) + "cm.");

  float lastError = 0.0;
  bool correctionActive = false;
  uint32_t lastLoopTime = 0;
  bool firstIteration = true;
  bool holdTimerStarted = false;
  uint32_t holdStartMs = 0;

  while (currentMode == expectedMode) {
    uint32_t loopStart = millis();

    float currentDepth = 0.0;
    uint32_t lastDepthMs = 0;
    bool depthFresh = false;
    if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
      currentDepth = currentRelativeDepth;
      lastDepthMs = lastValidDepthMs;
      depthFresh = depthReadingIsFresh(loopStart, lastDepthMs);
      xSemaphoreGive(dataLock);
    }

    if (!depthFresh) {
      uint32_t ageMs = lastDepthMs > 0 ? (loopStart - lastDepthMs) : 0;
      safeLog("[DOUBLE ACTIVE ERROR] Pressure sensor data stale during double timed active depth (age " + String(ageMs) + "ms). Surfacing.");
      return false;
    }

    float error = currentDepth - stageTargetDepth;

    if (!holdTimerStarted && fabs(error) <= toleranceMeters) {
      holdTimerStarted = true;
      holdStartMs = loopStart;
      if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
        currentSubStatus = holdingStatus;
        holdSecondsRemaining = holdTimeMs / 1000;
        xSemaphoreGive(modeLock);
      }
      safeLog(String("[DOUBLE ACTIVE] Target ") + stageLabel + " deadband reached. Hold timer started.");
    }

    if (holdTimerStarted) {
      uint32_t elapsedHoldMs = loopStart - holdStartMs;
      long remainingSeconds = 0;
      if (elapsedHoldMs < holdTimeMs) {
        remainingSeconds = (holdTimeMs - elapsedHoldMs + 999) / 1000;
      }

      if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
        holdSecondsRemaining = remainingSeconds;
        xSemaphoreGive(modeLock);
      }

      if (elapsedHoldMs >= holdTimeMs) {
        safeLog(String("[DOUBLE ACTIVE] ") + completionLog);
        return true;
      }
    }

    float actualDtSec;
    if (firstIteration) {
      actualDtSec = dtMs / 1000.0f;
      firstIteration = false;
    } else {
      actualDtSec = (loopStart - lastLoopTime) / 1000.0f;
      if (actualDtSec < 0.001f) actualDtSec = 0.001f;
    }
    lastLoopTime = loopStart;

    float derivative = (error - lastError) / actualDtSec;
    lastError = error;

    float output = (currentKp * error) + (currentKd * derivative);
    if (output < 0) output *= surfScale;

    if (!correctionActive) {
      if (fabs(error) > toleranceMeters) correctionActive = true;
    } else {
      if (fabs(error) < toleranceMeters * 0.7f) correctionActive = false;
    }

    if (correctionActive) {
      int stepsToTake = abs((int)output);
      if (stepsToTake > 500) stepsToTake = 500;

      if (output > 0) {
        bool limitHit = false;
        for (int i = 0; i < stepsToTake && currentMode == expectedMode; i++) {
          if (!singleStep(true, s_speed)) { limitHit = true; break; }
        }
        if (limitHit && digitalRead(BUTTON_PIN_1) == LOW) {
          safeLog("[SAFETY] Bottom limit hit during double timed active depth. Surfacing.");
          return false;
        }
      } else if (output < 0) {
        for (int i = 0; i < stepsToTake && currentMode == expectedMode; i++) {
          if (!singleStep(false, u_speed)) break;
        }
      }
    }

    uint32_t elapsed = millis() - loopStart;
    if (elapsed < dtMs) {
      vTaskDelay(pdMS_TO_TICKS(dtMs - elapsed));
    }
  }

  return false;
}

void runDoubleTimedActiveDepthSequence() {
  float stage1Target = 0.0;
  float stage2Target = 0.0;
  uint32_t holdTimeMs = 30000;
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    stage1Target = doubleActiveTarget1;
    stage2Target = doubleActiveTarget2;
    holdTimeMs = doubleActiveHoldTimeMs;
    currentSubStatus = "SEEKING DEPTH 1";
    holdSecondsRemaining = 0;
    xSemaphoreGive(modeLock);
  }

  safeLog("[DOUBLE ACTIVE] Started. Target 1: " + String(stage1Target * 100.0) + "cm, Target 2: " + String(stage2Target * 100.0) + "cm.");

  float toleranceMeters = 0.03;
  float currentKp = 2500.0, currentKd = 800.0;
  int s_speed = 6000, u_speed = 6000;
  uint32_t dtMs = 100;
  float surfScale = 0.5;

  if (xSemaphoreTake(configLock, pdMS_TO_TICKS(50))) {
    toleranceMeters = depthToleranceCm / 100.0;
    currentKp = Kp;
    currentKd = Kd;
    s_speed = sinkHoldSpeed;
    u_speed = surfaceHoldSpeed;
    dtMs = pdLoopDelayMs;
    surfScale = surfaceOutputScale;
    xSemaphoreGive(configLock);
  }

  bool stage1Done = runDoubleTimedActiveStage(MODE_DOUBLE_TIMED_ACTIVE_DEPTH,
                                              stage1Target,
                                              "SEEKING DEPTH 1",
                                              "HOLDING DEPTH 1 (PD)",
                                              "depth 1",
                                              "Target depth 1 hold complete.",
                                              holdTimeMs,
                                              toleranceMeters,
                                              currentKp,
                                              currentKd,
                                              s_speed,
                                              u_speed,
                                              dtMs,
                                              surfScale);

  if (stage1Done && currentMode == MODE_DOUBLE_TIMED_ACTIVE_DEPTH) {
    runDoubleTimedActiveStage(MODE_DOUBLE_TIMED_ACTIVE_DEPTH,
                              stage2Target,
                              "SEEKING DEPTH 2",
                              "HOLDING DEPTH 2 (PD)",
                              "depth 2",
                              "Target depth 2 hold complete. Surfacing.",
                              holdTimeMs,
                              toleranceMeters,
                              currentKp,
                              currentKd,
                              s_speed,
                              u_speed,
                              dtMs,
                              surfScale);
  }

  if (currentMode == MODE_DOUBLE_TIMED_ACTIVE_DEPTH) {
    if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
      currentSubStatus = "SURFACING";
      holdSecondsRemaining = 0;
      xSemaphoreGive(modeLock);
    }

    surfaceEmergency();

    if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
      currentSubStatus = "IDLE";
      holdSecondsRemaining = 0;
      currentMode = MODE_IDLE;
      xSemaphoreGive(modeLock);
    }
    safeLog("[DOUBLE ACTIVE] Sequence complete. System IDLE.");
  }
}

// ==========================================
// --- MAIN MOTOR TASK (CORE 1) ---
// ==========================================
void motorTask(void *parameter) {
  while(1) {
    SystemMode m;
    if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
      m = currentMode;
      xSemaphoreGive(modeLock);
    }

    if (m == MODE_HOMING) {
      while(digitalRead(BUTTON_PIN_2) == HIGH && currentMode == MODE_HOMING) {
        singleStep(false);
        vTaskDelay(1);
      }
      bool homedNow = false;
      if (currentMode == MODE_HOMING) {
        currentStepperPos = 0;
        homedNow = true;
        safeLog("[SYSTEM] Home reference set to 0 steps.");
      }
      
      if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
        if (homedNow) isHomed = true;
        currentSubStatus = "IDLE";
        holdSecondsRemaining = 0;
        currentMode = MODE_IDLE;
        xSemaphoreGive(modeLock);
      }
    }
    else if (m == MODE_MANUAL_PULSE) {
      while(millis() - manualStartTime < manualDurationMs) {
        if (!singleStep(manualDir) || currentMode != MODE_MANUAL_PULSE) break;
        vTaskDelay(1);
      }
      
      if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
        currentSubStatus = "IDLE";
        holdSecondsRemaining = 0;
        currentMode = MODE_IDLE;
        xSemaphoreGive(modeLock);
      }
    }
    else if (m == MODE_TARGET_STEP_SEQUENCE) { 
      runTargetStepSequence();
    }
    else if (m == MODE_FULL_BUMP_SEQUENCE) {
      runFullBumpSequence();
    }
    else if (m == MODE_ACTIVE_DEPTH) {
      runActiveDepthSequence();
    }
    else if (m == MODE_TIMED_ACTIVE_HOLD) {
      runTimedActiveHoldSequence();
    }
    else if (m == MODE_DOUBLE_TIMED_ACTIVE_DEPTH) {
      runDoubleTimedActiveDepthSequence();
    }
    else {
      vTaskDelay(100);
    }
  }
}

// ==========================================
// --- DEDICATED OTA & DISCOVERY TASK (CORE 0) ---
// ==========================================
void otaTask(void *parameter) {
  while(1) {
    ArduinoOTA.handle();
    vTaskDelay(pdMS_TO_TICKS(10)); 
  }
}

// ==========================================
// --- SETUP & LOOP ---
// ==========================================
void setup() {
  Serial.begin(115200);
  delay(1000);
  
  Wire.begin(CUSTOM_SDA_PIN, CUSTOM_SCL_PIN);

  logLock = xSemaphoreCreateMutex();
  liveLogBuffer.reserve(3000);
  safeLog("[BOOT] System initialization started...");

  unsigned long start = millis();
  while (millis() - start < 5000) {
    if (initializeSensorBaseline("[BOOT]")) break;
    delay(250);
  }

  if (!sensorActive) {
    safeLog("[BOOT ERROR] MS5837 failed to initialize or baseline was unstable!");
  }

  pinMode(dirPin, OUTPUT);
  pinMode(stepPin, OUTPUT);
  pinMode(BUTTON_PIN_1, INPUT_PULLUP);
  pinMode(BUTTON_PIN_2, INPUT_PULLUP);

  WiFi.mode(WIFI_AP);
  WiFi.softAP(ssid, password);
  delay(500); 

  safeLog("[NET] Access Point started successfully!");
  safeLog("[NET] Network Name: " + String(ssid));
  safeLog("[NET] AP IP Address: " + WiFi.softAPIP().toString());

  if (MDNS.begin("sscfloat")) {
    safeLog("[NET] mDNS domain initialized: http://sscfloat.local");
    MDNS.addService("arduino", "tcp", 3232);
    MDNS.addService("http", "tcp", 80);
  }

  ArduinoOTA.begin();
  
  server.on("/data", handleData);
  server.on("/control", handleControl);
  server.on("/config", handleConfig);
  server.on("/live", handleLivePage);        
  server.on("/livedata", handleLiveData);   
  server.on("/lidata", handleLidaPage);
  server.on("/lidadata", handleLidaData);
  server.begin();

  dataLock = xSemaphoreCreateMutex();
  modeLock = xSemaphoreCreateMutex();
  configLock = xSemaphoreCreateMutex();

  if (logLock == NULL || dataLock == NULL || modeLock == NULL || configLock == NULL) {
    safeLog("[BOOT FATAL] Mutex creation failed. FreeRTOS tasks not started.");
    return;
  }

  bool tasksOk = true;
  if (xTaskCreatePinnedToCore(sensorTask, "Sens", 4096, NULL, 2, &sensorTaskHandle, 0) != pdPASS) {
    safeLog("[BOOT FATAL] Failed to start sensor task.");
    tasksOk = false;
  }
  if (xTaskCreatePinnedToCore(webTask, "Web", 4096, NULL, 1, &webTaskHandle, 0) != pdPASS) {
    safeLog("[BOOT FATAL] Failed to start web task.");
    tasksOk = false;
  }
  if (xTaskCreatePinnedToCore(otaTask, "OTA", 4096, NULL, 3, &otaTaskHandle, 0) != pdPASS) {
    safeLog("[BOOT FATAL] Failed to start OTA task.");
    tasksOk = false;
  }
  if (xTaskCreatePinnedToCore(motorTask, "Mot", 4096, NULL, 3, &motorTaskHandle, 1) != pdPASS) {
    safeLog("[BOOT FATAL] Failed to start motor task.");
    tasksOk = false;
  }

  if (!tasksOk) {
    safeLog("[BOOT FATAL] One or more FreeRTOS tasks failed to start.");
    return;
  }
  
  safeLog("[BOOT] FreeRTOS task schedules active. Float engine ready.");
}

void loop() {
  vTaskDelay(pdMS_TO_TICKS(1000));
}
